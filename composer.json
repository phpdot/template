{
    "name": "phpdot/template",
    "description": "Swoole-safe Twig integration with auto-discovered extensions for the PHPdot ecosystem.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Omar Hamdan",
            "email": "omar@phpdot.com"
        }
    ],
    "keywords": ["twig", "template", "swoole", "phpdot"],
    "require": {
        "php": ">=8.3",
        "phpdot/config": "^1.0",
        "phpdot/container": "^1.0",
        "phpdot/package": "^1.0",
        "psr/container": "^2.0",
        "twig/twig": "^3.10"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.94",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "PHPdot\\Template\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PHPdot\\Template\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse --memory-limit=256M",
        "cs-fix": "php-cs-fixer fix",
        "cs-check": "php-cs-fixer fix --dry-run --diff",
        "check": [
            "@test",
            "@analyse",
            "@cs-check"
        ]
    },
    "config": {
        "sort-packages": true
    }
}
